# SMTP — Gmail (utiliser un App Password)
# Créer un App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Email admin qui reçoit les notifications de réservation
ADMIN_EMAIL=your@email.com

# Admin dashboard — authentification
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET=your-jwt-secret-change-in-production

# Base de données PostgreSQL (ex: Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
