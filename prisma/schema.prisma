generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reservation {
  id           Int      @id @default(autoincrement())
  nom          String
  email        String
  phone        String?
  domeType     String
  domeLabel    String
  arrival      String
  departure    String
  nights       Int
  persons      Int
  packageType  String
  packageLabel String
  totalPrice   Float
  message      String?
  status       String   @default("en_attente")
  createdAt    DateTime @default(now())
}
